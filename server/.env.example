# Prism Server Config (.env.example)
# Copy this file to .env and fill in your values

# -- Server --
SERVER_PORT=8080
# debug | release
SERVER_MODE=debug

# -- Database (PostgreSQL) --
DATABASE_DSN=host=localhost user=postgres password=postgres dbname=Prism port=5432 sslmode=disable

# -- Redis --
REDIS_ADDR=localhost:6379
REDIS_PASSWORD=
REDIS_DB=0

# -- JWT --
# Replace with strong random strings (>=32 chars) in production
JWT_ACCESS_SECRET=change-me-access-secret-at-least-32-chars
JWT_REFRESH_SECRET=change-me-refresh-secret-at-least-32-chars
# Access token expiry in minutes
JWT_ACCESS_EXPIRY=15
# Refresh token expiry in days
JWT_REFRESH_EXPIRY=7

# -- AES (API Key encryption, must be exactly 32 bytes) --
AES_KEY=change-me-32-byte-aes-key-here!!

# -- SMTP (email verification code) --
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your@email.com
SMTP_PASSWORD=your-smtp-password
SMTP_FROM=noreply@Prism.local
# Verification code TTL in seconds
SMTP_CODE_TTL=300

# -- CORS (comma-separated allowed origins) --
CORS_ORIGINS=http://localhost:3000,http://localhost:3001
